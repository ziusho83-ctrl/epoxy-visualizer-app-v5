# Frontend endpoint (defaults to /api/quote)
VITE_QUOTE_WEBHOOK_URL=/api/quote

# Optional: email alerts via Resend (handled by /api/quote)
RESEND_API_KEY=
RESEND_FROM=quotes@yourdomain.com
RESEND_TO=you@yourdomain.com
# Optional separate sender for customer auto-replies
RESEND_AUTOREPLY_FROM=hello@yourdomain.com

# Optional: forward every lead to another webhook (Zapier/Make/Apps Script)
LEADS_FORWARD_WEBHOOK_URL=
